-.di-sentiment-bar-row { display: flex; align-items: center; gap: 14px; }
-.di-sentiment-bar-label { min-width: 60px; font-size: 14px; font-weight: 500; }
-.di-sentiment-bar-track { flex: 1; height: 20px; background: var(--gray-100); border-radius: var(--radius-full); overflow: hidden; }
-.di-sentiment-bar-fill { height: 100%; border-radius: var(--radius-full); transition: width 0.6s ease; }
-.di-sentiment-bar-value { min-width: 40px; font-size: 14px; font-weight: 600; text-align: right; }
-.di-discussion-topic { display: flex; justify-content: space-between; padding: 8px 0; font-size: 14px; }
-.di-topic-name { color: var(--text-secondary); }
-.di-topic-change { font-weight: 600; color: var(--green); }
-
-.text-green { color: var(--green); }
-.text-red { color: var(--red); }
-
-/* Market Opportunity Cards */
-.di-opportunity-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
-.di-opportunity-card { padding: 16px; border-radius: var(--radius-md); border-left: 4px solid; }
-.di-opportunity-card h5 { font-size: 15px; font-weight: 600; margin: 0 0 6px; }
-.di-opportunity-card p { font-size: 14px; color: var(--text-secondary); line-height: 1.5; margin: 0; }
-.di-opp-green { background: var(--green-light); border-color: var(--green); }
-.di-opp-blue { background: var(--blue-light); border-color: var(--blue); }
-.di-opp-orange { background: var(--orange-light); border-color: #E17055; }
-.di-opp-purple { background: var(--primary-bg); border-color: var(--primary); }
-
-/* Strategic Recommendation */
-.di-strategic-card {
-  background: linear-gradient(135deg, #2D3436 0%, #636E72 100%);
-  border-radius: var(--radius-lg);
-  padding: 28px;
-  color: var(--white);
-}
-.di-strategic-card h4 { display: flex; align-items: center; gap: 10px; font-size: 18px; margin: 0 0 14px; color: var(--white); }
-.di-strategic-card h5 { font-size: 16px; font-weight: 600; margin: 0 0 10px; color: var(--white); }
-.di-strategic-card p { font-size: 14px; color: rgba(255,255,255,0.8); line-height: 1.6; margin: 0 0 20px; }
-.di-strategic-stats {
-  display: grid;
-  grid-template-columns: repeat(3, 1fr);
-  gap: 14px;
-  text-align: center;
-  border-top: 1px solid rgba(255,255,255,0.2);
-  padding-top: 20px;
-}
-.di-s-value { font-size: 24px; font-weight: 800; color: var(--white); }
-.di-s-value.green { color: var(--green); }
-.di-s-label { font-size: 12px; color: rgba(255,255,255,0.6); margin-top: 4px; }
-
-/* Floating Ask Expert Button */
-.di-ask-expert-float {
-  position: fixed;
-  bottom: 32px;
-  right: 32px;
-  display: flex;
-  align-items: center;
-  gap: 10px;
-  padding: 12px 22px;
-  background: var(--white);
-  border: 1px solid var(--border-color);
-  border-radius: var(--radius-full);
-  box-shadow: 0 4px 20px rgba(0,0,0,0.12);
-  cursor: pointer;
-  font-family: var(--font-family);
-  font-size: 14px;
-  font-weight: 600;
-  color: var(--text-primary);
-  text-decoration: none;
-  transition: all 0.25s ease;
-  z-index: 99;
-}
-.di-ask-expert-float:hover {
-  transform: translateY(-3px);
-  box-shadow: 0 6px 28px rgba(0,0,0,0.16);
-  border-color: var(--primary);
-  color: var(--primary);
-}
-.di-expert-icon { font-size: 20px; }
